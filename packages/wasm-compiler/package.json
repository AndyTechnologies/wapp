{
  "name": "wasm-compiler",
  "version": "1.0.0",
  "description": "Compila archivos AssemblyScript (.wasm.ts, .ts, .asm) a WebAssembly",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "wasm-compiler": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "start": "node ./dist/cli.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm-legacy",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.m?tsx?$": [
        "ts-jest/legacy",
        {
          "tsconfig": "tsconfig.test.json",
          "useESM": true
        }
      ]
    }
  },
  "keywords": [
    "webassembly",
    "assemblyscript",
    "wasm",
    "compiler"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "assemblyscript": "^0.28.19",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "picocolors": "^1.1.1",
    "wapp-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
