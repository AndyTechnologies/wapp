{
  "name": "wapp-cli",
  "version": "1.0.0",
  "description": "Orquestador para compilar proyectos AssemblyScript a ejecutables nativos usando wasm-compiler + wasm-linker",
  "type": "module",
  "bin": {
    "wapp-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/cli.js",
    "dev": "tsc --watch",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx",
      ".mts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.m?tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "useESM": true
        }
      ]
    }
  },
  "dependencies": {
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "picocolors": "^1.1.1",
    "wapp-types": "workspace:*",
    "wasm-compiler": "workspace:*",
    "wasm-linker": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}